{
  "name": "viro",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"node scripts/run-with-project-root.mjs next dev --port 3007\" \"node scripts/run-with-project-root.mjs tsx scripts/bull-board.ts\"",
    "dev:next": "node scripts/run-with-project-root.mjs next dev --port 3007",
    "build": "node scripts/run-with-project-root.mjs next build",
    "start": "node scripts/run-with-project-root.mjs next start --port 3007",
    "lint": "node scripts/run-with-project-root.mjs eslint src next.config.ts",
    "lint:strict": "node scripts/run-with-project-root.mjs node scripts/eslint-gate.mjs",
    "lint:strict:all": "npm run lint -- --max-warnings=0",
    "bull-board": "node scripts/run-with-project-root.mjs tsx scripts/bull-board.ts",
    "test:harness": "node scripts/run-with-project-root.mjs tsx --test src/shared/lib/queue/task-job-harness.test.ts src/shared/lib/queue/sequence-harness.test.ts scripts/harness-verify.test.ts scripts/account-roster-harness.test.ts scripts/cafe-account-sheet-source.test.ts",
    "test:tooling": "node scripts/run-with-project-root.mjs node --test scripts/eslint-gate.test.mjs scripts/run-with-project-root.test.mjs",
    "accounts:check": "node scripts/run-with-project-root.mjs tsx --env-file=.env.local scripts/account-roster-harness.ts --check",
    "accounts:sheet:check": "node scripts/run-with-project-root.mjs tsx --env-file=.env.local scripts/sync-cafe-accounts-from-sheet.ts --check",
    "accounts:sync": "node scripts/run-with-project-root.mjs tsx --env-file=.env.local scripts/sync-cafe-accounts-from-sheet.ts --apply --check",
    "scan:low-comments": "node scripts/run-with-project-root.mjs tsx --env-file=.env.local scripts/scan-low-comment-articles.ts",
    "verify:task": "node scripts/run-with-project-root.mjs tsx scripts/harness-verify.ts",
    "verify:ci": "npm run lint:strict && npm run test:harness && npm run test:tooling && npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@bull-board/api": "^6.16.2",
    "@bull-board/express": "^6.16.2",
    "@google/genai": "^1.42.0",
    "bullmq": "^5.66.5",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "framer-motion": "^12.27.1",
    "googleapis": "^171.4.0",
    "ioredis": "^5.9.1",
    "jotai": "^2.16.2",
    "lottie-react": "^2.4.1",
    "lucide-react": "^1.24.0",
    "mongoose": "^9.1.2",
    "next": "16.1.1",
    "next-auth": "^5.0.0-beta.30",
    "playwright": "npm:rebrowser-playwright@^1.52.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
