{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true
  },
  "//": "lib 만 격리 타입체크. runtime.ts/cli.ts 는 ../src 프리미티브를 재사용하는 tsx 실행 진입점(scripts 와 동일 패턴)이라 여기서 제외한다.",
  "include": ["lib/**/*.ts"]
}
